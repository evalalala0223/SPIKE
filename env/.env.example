# Required: path to StardewModdingAPI.
# Windows example:
# STARDEW_APP_PATH=C:\Program Files (x86)\Steam\steamapps\common\Stardew Valley\StardewModdingAPI.exe
STARDEW_APP_PATH=

# Qwen / DashScope OpenAI-compatible endpoint.
DASHSCOPE_API_KEY=

# OpenAI.
OPENAI_API_KEY=

# Gemini.
GEMINI_API_KEY=

# Optional runtime knobs.
FIXED_SEED=true
PYTHONHASHSEED=42
